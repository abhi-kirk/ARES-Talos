      "y": 1932.2187709872399,
      "width": 438.46457353928804,
      "height": 232.55960376091318,
      "angle": 0,
      "strokeColor": "#2e7d32",
      "backgroundColor": "#ddffdd",
      "fillStyle": "solid",
