    {
      "id": "c64b9cceec87467a",
      "type": "text",
      "x": 116.45811583324914,
      "y": 1610.1252938213565,
      "width": 459.9541931152344,
      "height": 120,
      "angle": 0,
      "strokeColor": "#2e7d32",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
