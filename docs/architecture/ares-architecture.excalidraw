      "seed": 1123305996,
      "version": 90,
      "versionNonce": 501066140,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771692868307,
      "link": null,
      "locked": false,
      "text": "Inner loop (Reflex) — runs on MCU (deterministic)\n\nRate: 500–1000 Hz\nInputs: IMU + encoders\nCompute: state estimate (θ, θ̇, v) + controller (PID/LQR)\nOutput: motor command → Sabertooth PWM",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 16,
      "containerId": "8750acc3f4b8433b",
      "originalText": "Inner loop (Reflex) — runs on MCU (deterministic)\n\nRate: 500–1000 Hz\nInputs: IMU + encoders\nCompute: state estimate (θ, θ̇, v) + controller (PID/LQR)\nOutput: motor command → Sabertooth PWM",
      "lineHeight": 1.25,
      "index": "b02",
      "frameId": "313c8b46e44c43b2",
      "autoResize": true
    },
    {
      "id": "fe032811916a429e",
      "type": "rectangle",
