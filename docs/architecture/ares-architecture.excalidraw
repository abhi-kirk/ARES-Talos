      "isDeleted": false,
      "boundElements": [],
      "updated": 1770597004087,
      "link": null,
      "locked": false,
      "text": "Outer loop (Thinking) — runs on Jetson (Linux)\n\nRate: ~20–50 Hz\nInputs: telemetry from MCU, optional cameras\nCompute: trajectory / MPC / velocity control / vision\nOutput: setpoints to MCU (desired velocity/angle)",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 16,
      "containerId": "fe032811916a429e",
      "originalText": "Outer loop (Thinking) — runs on Jetson (Linux)\n\nRate: ~20–50 Hz\nInputs: telemetry from MCU, optional cameras\nCompute: trajectory / MPC / velocity control / vision\nOutput: setpoints to MCU (desired velocity/angle)",
      "lineHeight": 1.25,
      "index": "b04",
      "frameId": "313c8b46e44c43b2",
      "autoResize": true
    },
