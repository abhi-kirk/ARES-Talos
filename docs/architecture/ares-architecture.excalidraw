      "boundElements": [],
      "updated": 1771692857777,
      "link": null,
      "locked": false,
      "text": "Signals\n\nMCU ↔ Jetson: USB serial or UART\n- Setpoints: v_ref, mode, e-stop\n- Telemetry: θ, θ̇, v, pwm, battery\n\nMCU → Sabertooth: PWM\nSensors → MCU: I²C + encoder A/B",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 16,
      "containerId": "61b6d146441144f7",
      "originalText": "Signals\n\nMCU ↔ Jetson: USB serial or UART\n- Setpoints: v_ref, mode, e-stop\n- Telemetry: θ, θ̇, v, pwm, battery\n\nMCU → Sabertooth: PWM\nSensors → MCU: I²C + encoder A/B",
      "lineHeight": 1.25,
      "index": "b0A",
      "frameId": "313c8b46e44c43b2",
      "autoResize": true
    },
