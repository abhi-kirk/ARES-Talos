    {
      "id": "aeec8e1ed2464056",
      "type": "text",
      "x": 137.7752863036617,
      "y": 1988.4985728676963,
      "width": 422.0157470703125,
      "height": 120,
      "angle": 0,
      "strokeColor": "#2e7d32",
      "backgroundColor": "transparent",
