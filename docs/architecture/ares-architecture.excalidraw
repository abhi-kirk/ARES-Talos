      "text": "Diagram 3 — Control Loops (Inner vs Outer loop)",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 20,
      "containerId": "14225e28ef1d40ca",
      "originalText": "Diagram 3 — Control Loops (Inner vs Outer loop)",
      "lineHeight": 1.25,
      "index": "b00",
      "frameId": null,
      "autoResize": true
